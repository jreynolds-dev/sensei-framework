{
  "name": "sensei",
  "version": "1.0.0",
  "description": "A reusable, character-swappable teaching plugin for Claude Code. Turn any project into a guided learning dojo with adaptive difficulty, spaced repetition, and rich session commands.",
  "author": {
    "name": "jreynolds-dev"
  },
  "repository": "https://github.com/jreynolds-dev/sensei",
  "license": "MIT",
  "keywords": ["teaching", "learning", "education", "mentor", "socratic", "adaptive"],
  "commands": [
    "./commands/setup.md",
    "./commands/dojo-open.md",
    "./commands/pizza-time.md",
    "./commands/notecards.md",
    "./commands/show-me.md",
    "./commands/why.md",
    "./commands/challenge-me.md",
    "./commands/spar.md",
    "./commands/progress-report.md",
    "./commands/commands.md",
    "./commands/sensei-check.md",
    "./commands/set-mode.md",
    "./commands/teach-back.md"
  ],
  "hooks": "./hooks/hooks.json",
  "engines": {
    "claude-code": ">=2.1.0"
  }
}
